# -----------------------------------------------------------------------------
# Part2 - Environment variables (single source of truth for automation)
# Copy to: .env   (never commit real secrets)
# -----------------------------------------------------------------------------

# =============================================================================
# Palo Alto (PAN-OS)
# =============================================================================
# Management IP/FQDN reachable from the container
PAN_HOST=192.168.1.245

# API key (preferred for automation; stable, no interactive login)
# REQUIRED by your playbooks 02/03/00 when using API calls.
PAN_API_KEY=LUFRPT1lMW8ranVkeGM2L0pHbzQvclI5V3dIbUtVT2s9aTNobUlMdnhNalJZb0syY2ZsTzNoNEtKOXQrZ3E4VHgxbk5ZNG9EMW5TTmJmNTdWcUxyUVRyWmdnM0Fxa2tWOQ==

# Optional credentials (ONLY needed if you implement runtime keygen)
# Keep commented if you always provide PAN_API_KEY.
# PAN_USERNAME=admin
# PAN_PASSWORD=admin

# Optional (only if you ever add custom port handling in uri URLs)
# Default is 443 in the playbooks as https://PAN_HOST/api
# PAN_HTTPS_PORT=443

# Optional inventory-style defaults (ONLY if your playbooks read them)
# PAN_WAN_IF=ethernet1/3
# PAN_VR=default
# PAN_VSYS=vsys1
# PAN_DEVICE_ENTRY=localhost.localdomain


# =============================================================================
# FortiGate (FortiOS)
# =============================================================================
# Management IP/FQDN reachable from the container
FGT_HOST=192.168.1.240

# Credentials for FortiOS REST API (required to avoid 401 in evidence)
FGT_USER=admin
FGT_PASS=admin

# FortiGate API access method
# If your FGT mgmt is HTTPS set true and port 443.
FGT_USE_SSL=false
FGT_HTTP_PORT=80

# VDOM used by the playbooks (default root)
FGT_VDOM=root

# If you use self-signed certs in HTTPS
FGT_VERIFY_SSL=false


# =============================================================================
# Runtime / Evidence / Backups
# =============================================================================
# Optional: fixed timestamp folder name (if empty, playbooks compute date)
RUN_TS=

# Base paths inside container (match your repo structure)
EVIDENCE_BASE=/app/part2/evidence
BACKUPS_BASE=/app/part2/backups


# =============================================================================
# Validation traffic (Bonus MELI)
# =============================================================================
# These must be reachable behind each side to prove "real traffic"
VPN_VALIDATE_PAN_TO_FGT_LAN_IP=10.10.10.10
VPN_VALIDATE_FGT_TO_PAN_LAN_IP=10.20.10.10


# =============================================================================
# VPN shared secret (ONLY if you changed playbooks to read it from env)
# If your playbooks take PSK from group_vars/all/vpn.yml, keep this commented.
# =============================================================================
# VPN_PSK=Meli2026!